        - id: b000000000000000000000000000000b
          blockGroup: g0000000-0000-0000-0000-00000000000b
          sortingKey: "000010"
          contentHash: sha256:923b60c7bc121c9c74a8b8d314cf202730151c81b683cf97f4b23e3f401f6820
          executionCount: 9
          outputs:
            - output_type: stream
              name: stdout
              text: >
                Q1 2026 Sales Review — All regions, last 6 months (as of 2026-03-31)
          type: code
          content: >-
            import numpy as np

            import pandas as pd

            import matplotlib

            matplotlib.use("Agg")

            import matplotlib.pyplot as plt


            # --- deterministic synthetic data: monthly revenue ($k) by region ----------

            MONTHS = pd.period_range("2025-04", periods=12, freq="M").astype(str).tolist()

            REGIONS = ["North America", "Europe", "Asia Pacific", "Latin America"]

            BASE = {"North America": 320, "Europe": 260, "Asia Pacific": 210, "Latin America": 120}

            GROWTH = {"North America": 1.010, "Europe": 1.018, "Asia Pacific": 1.030, "Latin America": 1.022}


            rng = np.random.default_rng(42)

            rows = [
                {"month": m, "region": r, "revenue_k": round(BASE[r] * GROWTH[r] ** i * rng.uniform(0.92, 1.10), 1)}
                for r in REGIONS
                for i, m in enumerate(MONTHS)
            ]

            df = pd.DataFrame(rows)


            # --- apply the notebook inputs (input values arrive as strings) -------------

            def _num(x):
                return float(str(x))

            months = max(1, min(12, int(_num(trailing_months))))

            target_monthly = int(_num(target_revenue_k)) * 1000

            target_total = target_monthly * months

            forecast_on = str(show_forecast).lower() in ("true", "1")

            selected = None if region == "All regions" else region


            window = MONTHS[-months:]

            view = df[df["month"].isin(window)]

            if selected:
                view = view[view["region"] == selected]

            print(f"{report_title} — {selected or 'All regions'}, last {months} months (as of {as_of})")
          metadata: {}
        - id: b000000000000000000000000000000c
          blockGroup: g0000000-0000-0000-0000-00000000000c
          sortingKey: "000011"
          contentHash: sha256:d4402080d9184ff14e13204791713218cd33045222e726f2867d4a7b1af25a40
          executionCount: 10
          outputs:
            - output_type: execute_result
              data:
                text/plain: <IPython.core.display.HTML object>
                text/html: >
                  
                  <div
                  style="display:flex;gap:12px;flex-wrap:wrap;font-family:system-ui,-apple-system,sans-serif;color:inherit">
                    <div style="flex:1;min-width:160px;border:1px solid rgba(128,128,128,.28);border-radius:8px;padding:14px 16px">
                      <div style="font-size:11px;letter-spacing:.06em;text-transform:uppercase;opacity:.6">Revenue · 6 mo</div>
                      <div style="font-size:26px;font-weight:650;margin-top:4px">$6,572,100</div>
                      <div style="font-size:13px;margin-top:2px;color:#0e8f8f">
                        ▲ 13.7% vs prior period
                      </div>
                    </div>
                    <div style="flex:1;min-width:160px;border:1px solid rgba(128,128,128,.28);border-radius:8px;padding:14px 16px">
                      <div style="font-size:11px;letter-spacing:.06em;text-transform:uppercase;opacity:.6">To target</div>
                      <div style="font-size:26px;font-weight:650;margin-top:4px">110%</div>
                      <div style="font-size:13px;margin-top:2px;opacity:.6">target $6,000,000</div>
                    </div>
                    <div style="flex:1;min-width:160px;border:1px solid rgba(128,128,128,.28);border-radius:8px;padding:14px 16px">
                      <div style="font-size:11px;letter-spacing:.06em;text-transform:uppercase;opacity:.6">Top region</div>
                      <div style="font-size:19px;font-weight:650;margin-top:8px">North America</div>
                      <div style="font-size:13px;margin-top:2px;opacity:.6">by revenue in window</div>
                    </div>
                  </div>
              metadata: {}
              execution_count: 10
          type: code
          content: >-
            from IPython.display import HTML


            total = float(view["revenue_k"].sum()) * 1000

            pct = total / target_total * 100 if target_total else 0.0


            prior = MONTHS[-(2 * months):-months]

            prior_view = df[df["month"].isin(prior)]

            if selected:
                prior_view = prior_view[prior_view["region"] == selected]
            prior_total = float(prior_view["revenue_k"].sum()) * 1000

            delta = (total / prior_total - 1) * 100 if prior_total else 0.0


            up = delta >= 0

            top_region = view.groupby("region")["revenue_k"].sum().idxmax()

            card = "flex:1;min-width:160px;border:1px solid rgba(128,128,128,.28);border-radius:8px;padding:14px 16px"

            cap = "font-size:11px;letter-spacing:.06em;text-transform:uppercase;opacity:.6"

            big = "font-size:26px;font-weight:650;margin-top:4px"

            HTML(f'''

            <div
            style="display:flex;gap:12px;flex-wrap:wrap;font-family:system-ui,-apple-system,sans-serif;color:inherit">
              <div style="{card}">
                <div style="{cap}">Revenue · {months} mo</div>
                <div style="{big}">${total:,.0f}</div>
                <div style="font-size:13px;margin-top:2px;color:{'#0e8f8f' if up else '#c02a4b'}">
                  {'▲' if up else '▼'} {abs(delta):.1f}% vs prior period
                </div>
              </div>
              <div style="{card}">
                <div style="{cap}">To target</div>
                <div style="{big}">{pct:.0f}%</div>
                <div style="font-size:13px;margin-top:2px;opacity:.6">target ${target_total:,.0f}</div>
              </div>
              <div style="{card}">
                <div style="{cap}">Top region</div>
                <div style="font-size:19px;font-weight:650;margin-top:8px">{top_region}</div>
                <div style="font-size:13px;margin-top:2px;opacity:.6">by revenue in window</div>
              </div>
            </div>

            ''')
          metadata: {}
