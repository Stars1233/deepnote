        - id: b000000000000000000000000000000e
          blockGroup: g0000000-0000-0000-0000-00000000000e
          sortingKey: "000013"
          contentHash: sha256:55df40d80aa5ec8a99afc3552d66ae396a5bd588443234a349a01f94e31d20ad
          executionCount: 12
          outputs:
            - output_type: display_data
              data:
                image/png: 
                text/plain: <IPython.core.display.Image object>
              metadata: {}
          type: code
          content: >-
            import io

            from IPython.display import Image, display


            monthly = (view.groupby("month")["revenue_k"].sum().reindex(window).fillna(0) * 1000)


            fig, ax = plt.subplots(figsize=(7, 3.2), dpi=120)

            ax.plot(range(len(window)), monthly.values, marker="o", lw=2, color="#4a25c9", label="Revenue")

            ax.axhline(target_monthly, ls="--", lw=1.3, color="#0e8f8f", label="Target / mo")


            if forecast_on and len(window) >= 3:
                recent = monthly.values[-3:]
                step = (recent[-1] - recent[0]) / 2
                fc = [monthly.values[-1] + step * k for k in (1, 2)]
                ax.plot([len(window) - 1, len(window), len(window) + 1],
                        [monthly.values[-1], *fc], ls=":", lw=1.8, color="#c56b1b", label="Forecast")

            ax.set_xticks(range(len(window)))

            ax.set_xticklabels([m[2:] for m in window], fontsize=8)

            ax.set_ylabel("Revenue ($)")

            ax.set_title("Monthly revenue vs target")

            ax.legend(fontsize=8, frameon=False, loc="upper left")

            ax.grid(axis="y", alpha=.15)

            for s in ("top", "right"):
                ax.spines[s].set_visible(False)
            fig.tight_layout()


            # Render headlessly to a PNG so the output is a real image (works with the Agg backend).

            buf = io.BytesIO()

            fig.savefig(buf, format="png", bbox_inches="tight")

            plt.close(fig)

            display(Image(data=buf.getvalue(), format="png"))
          metadata: {}
        - id: b000000000000000000000000000000f
          blockGroup: g0000000-0000-0000-0000-00000000000f
          sortingKey: "000014"
          contentHash: sha256:51c054f538a4d310ca21a5c38acfa6d9ad92db17055dcac323714153f4588dee
